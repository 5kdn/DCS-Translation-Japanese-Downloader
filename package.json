{
  "name": "dcs-translation-japanese-downloader",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "license": "MIT",
  "pnpm": {
    "patchedDependencies": {
      "@microsoft/kiota-abstractions@1.0.0-preview.99": "patches/@microsoft__kiota-abstractions@1.0.0-preview.99.patch"
    }
  },
  "scripts": {
    "dev": "vite --port 5177",
    "build": "pnpm run generate-licenses && vue-tsc -b && vite build",
    "test": "pnpm run test:unit && pnpm run test:storybook",
    "test:unit": "vitest --run --project vitest",
    "test:storybook": "pnpm exec playwright install && vitest --run --project storybook",
    "lint": "biome lint .",
    "fmt": "biome format . --write",
    "check": "biome check .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-apiClient": "kiota generate --openapi https://dcs-translation-japanese-cloudflare-worker.dcs-translation-japanese.workers.dev/openapi.json --language TypeScript --clean-output -o src/lib/http/apiClient",
    "update-apiClient": "kiota update -o src/lib/http/ --clean-output",
    "generate-licenses": "license-checker-rseidelsohn --json --production --excludePrivatePackages --out src/assets/LICENSES/licenses.json --customPath license-checker-rseidelsohn-customFormat.json --clarificationsFile license-checker-rseidelsohn-license-clarifications.json",
    "chromatic": "pnpx chromatic"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@microsoft/kiota-abstractions": "1.0.0-preview.99",
    "@microsoft/kiota-http-fetchlibrary": "1.0.0-preview.99",
    "@microsoft/kiota-serialization-form": "1.0.0-preview.99",
    "@microsoft/kiota-serialization-json": "1.0.0-preview.99",
    "@microsoft/kiota-serialization-multipart": "1.0.0-preview.99",
    "@microsoft/kiota-serialization-text": "1.0.0-preview.99",
    "dompurify": "^3.4.0",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "vue": "^3.5.32",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "@vue/language-plugin-pug": "^3.2.7",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "playwright": "^1.59.1",
    "sass": "^1.99.0",
    "storybook": "^10.3.5",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
